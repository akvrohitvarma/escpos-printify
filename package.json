{
  "name": "escpos-printify",
  "version": "2.0.0",
  "description": "HTML to thermal receipt printer server with web UI",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:web": "cd web && npm run build"
  },
  "keywords": ["escpos", "receipt", "printer", "thermal"],
  "author": "Kumara Venkata",
  "license": "MIT",
  "dependencies": {
