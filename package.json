    "@resvg/resvg-js": "^2.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "escpos": "^3.0.0-alpha.6",
    "escpos-network": "^3.0.0-alpha.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "qrcode": "^1.5.4",
    "satori": "^0.12.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.33.0"
  },
  "optionalDependencies": {
    "escpos-usb": "^3.0.0-alpha.4"
