# ESC/POS Printify Configuration

# Server
PORT=3000

# Printer Network Settings
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100

# Image Settings (58mm paper = 384, 80mm paper = 512)
IMAGE_WIDTH=512

# Timeouts (ms)
PRINTER_TIMEOUT=10000

# Rate Limiting
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60000

# Render concurrency (max simultaneous image renders, prevents OOM)
MAX_CONCURRENT_RENDERS=3

# Security (optional)
# API_KEY=your-secret-key-here
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
